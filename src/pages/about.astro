---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About me',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero>
    <Fragment slot="title">
      About <br />
      <span class="text-accent dark:text-white"> Rachael Glazner</span>
    </Fragment>

    <Fragment slot="subtitle">
      Hello! I am an aspiring software engineer with a background in scientific education and research. On this page, you can find some basic information about me!
    </Fragment>
  </Hero>

  <!-- Features3 Widget ************** -->

  <Features3
    title="Education"
    subtitle="I have a diverse set of degrees which reflects my adaptable learning abilities and broad academic interests."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'B.S. Applied Computer Science',
        description:
          'University of Colorado Boulder, Estimated Completeion: August 2026',
        icon: 'tabler:device-desktop',
      },
      {
        title: 'Ph.D. Ecology and Evolutionary Biology',
        description:
          'Texas A&M University College Station, August 2020',
        icon: 'tabler:tree',
      },
      {
        title: 'B.S. Biology',
        description:
          'Plymouth State University, May 2015',
        icon: 'tabler:microscope',
      },
    ]}
  />


  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Technical Skills"
    subtitle="Through academic and work experience, I have acquired skills across multiple languages and tools."
    items={[
      {
        title: 'Programming Languages',
        description:
          'Python, C++, R, Scala',
      },
      {
        title: 'Tools and Frameworks',
        description:
          'GitHub, GitLab, VS Code, Jupyter, GIS, Flake8, Cppcheck/Cpplint',
      },
      {
        title: 'Operating Systems',
        description:
          'Linux, iOS, Windows',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Awards and Achievements"
    subtitle="I have received a variety of grants, fellowships, and recognitions across my academic and professional career."
    isReversed={true}
    callToAction={{
      text: 'See more',
      href: '/',
    }}
    items={[
      {
        title: 'Texas A&M Boost Fellowship',
        icon: 'tabler:award',
      },
      {
        title: 'TAMUG Competitive Graduate Fellowship',
        icon: 'tabler:award',
      },
      {
        title: 'Texas Sea Grant-In-Aid of Research Award',
        icon: 'tabler:award',
      },
      {
        title: 'Ecology & Evolutionary Biology Research Award',
        icon: 'tabler:award',
      },
      {
        title: 'Plymouth State Top 20 Graduating Seniors ',
        description: 'Selected for academic excellence, community involvement, and character',
        icon: 'tabler:award',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Contact Information"
    columns={4}
    items={[
      {
        title: 'Email Address',
        description: 'ragl8391@colorado.edu',
      },
      {
        title: 'Australia',
        description: '9012 Lorem Ipsum St, 90123, Sydney',
      },
      {
        title: 'Brazil',
        description: '3456 Lorem Ipsum St, 34567, São Paulo',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Technical Support"
    tagline="Contact us"
    columns={2}
    items={[
      {
        title: 'Chat with us',
        description:
          'Integer luctus laoreet libero, auctor varius purus rutrum sit amet. Ut nec molestie nisi, quis eleifend mi.',
        icon: 'tabler:messages',
      },
      {
        title: 'Call us',
        description:
          'Mauris faucibus finibus orci, in posuere elit viverra non. In hac habitasse platea dictumst. Cras lobortis metus a hendrerit congue.',
        icon: 'tabler:headset',
      },
    ]}
  />
</Layout>
