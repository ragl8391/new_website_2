---
import Layout from '~/layouts/LandingLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import FAQs from '~/components/widgets/FAQs.astro';

const metadata = {
  title: 'CI/CD Research',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <FAQs
    tagline="Research Updates"
    title="CI/CD Pipelines"
    subtitle="Overview of the important software development component"
    items={[
      {
        title: "What is CI/CD?",
        description: "CI stands for Continuous Integration, and CD stands for Continuous Delivery/Deployment",
      },
      {
      title: "Why is CI/CD important?",
      description: "CI/CD gives software developers a streamlined way to test and merge code changes in an automated way that reduces merge conflicts at the end of the process.",
      },
      {
        title: "What are the core components of CI/CD?",
        description: "Continuous Integration automatically tests each commit, and rejects a code build if a test fails. Continuous Delivery automatically deploys passing code to a staging area. Continuous Deployment automically deplays passing code to production.",
      },
    ]}
  />

  <CallToAction
    title="Coming soon"
    subtitle="We are working on the content of these demo pages. You will see them very soon. Stay tuned Stay tuned!"


  />
</Layout>
