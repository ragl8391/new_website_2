---
import Layout from '~/layouts/LandingLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'CI/CD Research',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero
    tagline="Research Updates"
    title="CI/CD Pipelines"
    subtitle="Overview of the important software development component"
    
    image={{
      src: '/landing/before_ci_cd.webp',
      alt: 'Before CI/CD (Source: Geeks for Geeks)',
    }}
  />

  <Hero
    tagline="More Info"
    title="What Are They?"
    actions={[
      text: "CI stands for Continuous Integration, and CD stands for Continuous Delivery/Deployment",

    ]}

  />

  <CallToAction
    title="Coming soon"
    subtitle="We are working on the content of these demo pages. You will see them very soon. Stay tuned Stay tuned!"
      image={{
      src: '/landing/after_ci_cd.webp',
      alt: 'After CI/CD (Source: Geeks for Geeks)',
    }}
  />
</Layout>
