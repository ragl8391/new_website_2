---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Brands from '~/components/widgets/Brands.astro';

import { YouTube } from 'astro-embed';

const metadata = {
  title: 'Week 7 Updates',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero>
    <Fragment slot="title">
      Welcome to <span class="hidden sm:inline">Week 8</span> Updates <span
        class="text-accent dark:text-white"></span
      >
    </Fragment>

    <Fragment slot="subtitle">
      Scroll to read more about this week's work!
    </Fragment>
  </Hero>

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Weekly Summary"
    items={[
      {
        title: 'What did you do last week?',
        description:
          'Last week, I completed my project update report. I received some good feedback regarding the metrics I can keep track of during the linting process.',
      },
      {
        title: 'What do you plan to do this week?',
        description:
          'This week I made significant progress on linting. I also plan to quantify the linting errors and how often they appear, and I want to try to create a graphic illustrating which ones tend to appear the most. My goal is to completely finish the remaining Python files for linting by the end of the week. I might also see if there is any research published about which linting errors tend to appear more commonly.',
      },
      {
        title: 'Are there any impediments in your way?',
        description:
          'I am worried about having enough time to both lint files and to create the summary graphics of the different warnings, but I am hoping with more time during spring break I can get caught up.',
      },
      {
        title: 'Reflection on the process you used last week, how can you make the process work better?',
        description:
           'I had a little extra time on Monday to lint, which was helpful with staying on pace with my project. I am hoping the extra time during spring break will continue to help me stay on track.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </FAQs>
