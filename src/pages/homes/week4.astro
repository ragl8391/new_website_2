---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Brands from '~/components/widgets/Brands.astro';

import { YouTube } from 'astro-embed';

const metadata = {
  title: 'Week 4 Updates',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero>
    <Fragment slot="title">
      Welcome to <span class="hidden sm:inline">Week 4</span> Updates <span
        class="text-accent dark:text-white"></span
      >
    </Fragment>

    <Fragment slot="subtitle">
      Scroll to read more about this week's work!
    </Fragment>
  </Hero>

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Weekly Summary"
    items={[
      {
        title: 'What did you do last week?',
        description:
          'Last week I identified which files I would like to use for my code cleanup.',
      },
      {
        title: 'What do you plan to do this week?',
        description:
          'This week I read and reviewed 3 peer’s research proposals. For my project, I plan to research CI/CD Pipelines and begin my configuration file.',
      },
      {
        title: 'Are there any impediments in your way?',
        description:
          'As always, time is an issue for me. I am optimistic with a 3-day weekend due to the holiday that I will have more time to focus on my coursework.',
      },
      {
        title: 'Reflection on the process you used last week, how can you make the process work better?',
        description:
          'Continuing to plan a chunk of time during the weekend to work has been an effective way to accomplish weekly goals and tasks. I also appreciate the detailed feedback from the professor on discussion posts and assignments related to my project.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </FAQs>
