---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Brands from '~/components/widgets/Brands.astro';

import { YouTube } from 'astro-embed';

const metadata = {
  title: 'Week 10 Updates',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero>
    <Fragment slot="title">
      Welcome to <span class="hidden sm:inline">Week 10</span> Updates <span
        class="text-accent dark:text-white"></span
      >
    </Fragment>

    <Fragment slot="subtitle">
      Scroll to read more about this week's work!
    </Fragment>
  </Hero>

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Weekly Summary"
    items={[
      {
        title: 'What did you do last week?',
        description:
          'Last week I completed the Lifelong Learning Resources assignment, with a focus on handling exceptions in C++. I found it very helpful for covering topics that I have had less exposure to. I have officially completed my Python linting (I counted 84 files linted!).',
      },
      {
        title: 'What do you plan to do this week?',
        description:
          'This week I plan to begin linting C++ files, and I will summarize the major errors being found to compare them with the Python errors. I also hope to tackle the introduction/background of my final report over the weekend.',
      },
      {
        title: 'Are there any impediments in your way?',
        description:
          'I am curious as to how the scripting will compare when I try it with C++ to generate error type summaries. I am wondering if processing output will be more challenging with C++, but I will find out soon!',
      },
      {
        title: 'Reflection on the process you used last week, how can you make the process work better?',
        description:
           'Last week, I completed the Lifelong Learning Resources in 2-3 chunks of time rather than all at once, which helped make the work more manageable. My plan this week is to continue to chunk the work in a manageable way, with discussion posts, weekly updates, and linting happening during the week, and report work being the focus over the weekend.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </FAQs>
